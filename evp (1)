#!/usr/bin/env python3
"""
evp - EVIL pAnager (package + manager)
A sane wrapper around Gentoo's emerge that behaves like a normal package manager
"""

import sys
import subprocess
import os
import time
import threading
from pathlib import Path

# ============================================================================
# SPINNERS - Edit these to your heart's content!
# ============================================================================
