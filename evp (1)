    'dots': ['⠋', '⠙', '⠹', '⠸', '⠼', '⠴', '⠦', '⠧', '⠇', '⠏'],
    'gentoo': ['c', 'o', 'm', 'p', 'i', 'l', 'i', 'n', 'g', '.', '.', '.'],
    'penguin': ['🐧   ', ' 🐧  ', '  🐧 ', '   🐧', '  🐧 ', ' 🐧  '],
    'fire': ['🔥   ', ' 💥  ', '  ✨ ', '   ⚡', '  ✨ ', ' 💥  '],
