"""
    print(help_text)
    return 0


# ============================================================================
# Main
# ============================================================================
def main():
    global DRY_RUN
    
    if len(sys.argv) < 2:
        show_help()
        return 1
    
    # Check for --dry-run flag
    args = sys.argv[1:]
    if "--dry-run" in args:
        DRY_RUN = True
        args.remove("--dry-run")
        print("🔍 DRY RUN MODE - no changes will be made\n")
    
    if not args:
        show_help()
        return 1
    
    command = args[0]
    rest = args[1:]
    
    # Check if running as root for operations that need it
    needs_root = ["install", "remove", "update", "upgrade", "use", "use-remove", 
                  "repo-add", "repo-remove", "keyword", "keyword-remove", 
                  "license", "config-update"]
    
    if command in needs_root and os.geteuid() != 0 and not DRY_RUN:
        print(f"⚠ '{command}' typically needs root privileges")
        print(f"  Try: sudo evp {' '.join(args)}")
        print(f"  Or: evp --dry-run {' '.join(args)} (to preview)")
    
    # Route commands
    if command == "install":
        return install(rest)
    elif command == "remove":
        force = False
        packages = rest
        if packages and packages[0] in ["-f", "--force"]:
            force = True
            packages = packages[1:]
        return remove(packages, force)
    elif command == "update":
        return update()
    elif command == "upgrade":
        return upgrade()
    elif command == "search":
        return search(rest)
    elif command == "list":
        return list_installed()
    elif command == "info":
        return info(rest)
    
    # USE flags
    elif command == "use":
        return use_flags(rest)
    elif command == "use-remove":
        return use_remove(rest)
    elif command == "use-show":
        return use_show(rest)
    
    # Repositories
    elif command == "repo-add":
        return repo_add(rest)
    elif command == "repo-remove":
        return repo_remove(rest)
    elif command == "repo-list":
        return repo_list()
    
    # Keywords
    elif command == "keyword":
        return keyword_add(rest)
    elif command == "keyword-remove":
        return keyword_remove(rest)
    
    # Licenses
    elif command == "license":
        return license_add(rest)
    
    # Maintenance
    elif command == "logs":
        return show_logs(rest)
    elif command == "config-update":
        return config_update()
    
    # Help
    elif command in ["help", "--help", "-h"]:
        return show_help()
    
    else:
        print(f"Unknown command: {command}")
        print("Run 'evp help' for usage")
        return 1


if __name__ == "__main__":
    sys.exit(main())
