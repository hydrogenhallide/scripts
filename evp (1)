    'arrow': ['←', '↖', '↑', '↗', '→', '↘', '↓', '↙'],
}

# Pick your favorite!
ACTIVE_SPINNER = 'gentoo'

# ============================================================================
# Portage paths
# ============================================================================
MAKE_CONF = "/etc/portage/make.conf"
PACKAGE_USE = "/etc/portage/package.use"
PACKAGE_KEYWORDS = "/etc/portage/package.accept_keywords"
PACKAGE_LICENSE = "/etc/portage/package.license"
REPOS_CONF = "/etc/portage/repos.conf"
BUILD_LOG_DIR = "/var/tmp/portage"

# ============================================================================
# Global flags
# ============================================================================
DRY_RUN = False

# ============================================================================
# Spinner utility
# ============================================================================
class Spinner:
    def __init__(self, message="Working"):
        self.spinner = SPINNERS[ACTIVE_SPINNER]
        self.message = message
        self.running = False
        self.thread = None
    
    def _spin(self):
        idx = 0
        while self.running:
            sys.stdout.write(f"\r{self.message} {self.spinner[idx % len(self.spinner)]}")
            sys.stdout.flush()
            idx += 1
            time.sleep(0.1)
        sys.stdout.write("\r" + " " * (len(self.message) + 10) + "\r")
        sys.stdout.flush()
    
    def start(self):
        self.running = True
        self.thread = threading.Thread(target=self._spin)
        self.thread.start()
    
    def stop(self):
        self.running = False
        if self.thread:
            self.thread.join()

# ============================================================================
# Utilities
# ============================================================================
def run_command(cmd, explain=True, spinner_msg=None):
    """Run a command with optional spinner and explanation"""
    if explain:
        print(f"→ Running: {' '.join(cmd) if isinstance(cmd, list) else cmd}")
    
    if DRY_RUN:
        print("  (dry-run, not actually running)")
        return 0
    
    if spinner_msg:
        spinner = Spinner(spinner_msg)
        spinner.start()
        ret = subprocess.call(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        spinner.stop()
        return ret
    else:
        return subprocess.call(cmd)


def ensure_file_exists(path):
    """Ensure a file exists, create if it doesn't"""
    Path(path).parent.mkdir(parents=True, exist_ok=True)
    if not Path(path).exists():
        Path(path).touch()


def append_to_file(path, content):
    """Append content to a file"""
    ensure_file_exists(path)
    with open(path, 'a') as f:
        f.write(content + '\n')


def remove_from_file(path, pattern):
    """Remove lines containing pattern from file"""
    if not Path(path).exists():
        return
    
    with open(path, 'r') as f:
        lines = f.readlines()
    
    with open(path, 'w') as f:
        for line in lines:
            if pattern not in line:
                f.write(line)


# ============================================================================
# Package operations
# ============================================================================
def install(packages):
    """Install packages"""
    if not packages:
        print("Usage: evp install <package> [package...]")
        return 1
    return run_command(["emerge"] + packages, explain=True)


def remove(packages, force=False):
    """Remove packages (safely by default, forcefully with -f)"""
    if not packages:
        print("Usage: evp remove [-f] <package> [package...]")
        return 1
    
    if force:
        print("⚠ Force removing (--unmerge) - this ignores dependencies!")
        return run_command(["emerge", "-C"] + packages, explain=True)
    else:
        print("→ Deselecting packages from world...")
        ret = run_command(["emerge", "--deselect"] + packages, explain=True)
        if ret != 0:
            return ret
        
        print("\n→ Cleaning orphaned packages...")
        return run_command(["emerge", "--depclean", "-a"], explain=True)


def update():
    """Update repository metadata"""
    print("→ Syncing repositories...")
    return run_command(["emerge", "--sync"], explain=True, spinner_msg="Syncing repos")


def upgrade():
    """Upgrade installed packages"""
    print("→ Upgrading system packages...")
    return run_command(["emerge", "-uDN", "@world", "-a"], explain=True)


def search(term):
    """Search for packages"""
    if not term:
        print("Usage: evp search <term>")
        return 1
    return run_command(["emerge", "-s", term[0]])


def list_installed():
    """List installed packages"""
    if subprocess.call(["which", "qlist"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL) == 0:
        return subprocess.call(["qlist", "-I"])
    else:
        return run_command(["emerge", "@world", "-p"])


def info(packages):
    """Show package information"""
    if not packages:
        print("Usage: evp info <package>")
        return 1
    return run_command(["emerge", "-pv"] + packages)


# ============================================================================
# USE flag management
# ============================================================================
def use_flags(args):
    """Manage USE flags - global or per-package"""
    if not args:
        print("Usage: evp use [package] <flags>")
        print("Examples:")
        print("  evp use +kde -gnome           # Global USE flags")
        print("  evp use firefox -wayland      # Per-package USE")
        return 1
    
    # Check if first arg is a package name or a USE flag
    if args[0].startswith('+') or args[0].startswith('-'):
        # Global USE flags
        flags = ' '.join(args)
        print(f"→ Adding global USE flags: {flags}")
        
        if DRY_RUN:
            print(f"  Would add to {MAKE_CONF}: USE=\"{flags}\"")
            return 0
        
        # Read current USE flags from make.conf
        use_line = f'USE="${flags}"\n'
        
        # TODO: Better make.conf parsing - for now just append
        print(f"⚠ Appending to {MAKE_CONF}")
        print(f"  You may want to manually merge this with existing USE=\"...\" line")
        append_to_file(MAKE_CONF, use_line)
        
    else:
        # Per-package USE flags
        package = args[0]
        flags = ' '.join(args[1:])
        
        if not flags:
            print(f"Usage: evp use {package} <flags>")
            return 1
        
        print(f"→ Setting USE flags for {package}: {flags}")
        entry = f"{package} {flags}"
        
        if DRY_RUN:
            print(f"  Would add to {PACKAGE_USE}: {entry}")
            return 0
        
        append_to_file(PACKAGE_USE, entry)
    
    print("✓ Done! Run 'evp upgrade' to apply changes")
    return 0


def use_remove(args):
    """Remove USE flags"""
    if not args:
        print("Usage: evp use-remove <package> [flags]")
        return 1
    
    package = args[0]
    print(f"→ Removing USE flags for {package}")
    
    if DRY_RUN:
        print(f"  Would remove from {PACKAGE_USE}: {package}")
        return 0
    
    remove_from_file(PACKAGE_USE, package)
    print("✓ Done!")
    return 0


def use_show(args):
    """Show USE flags"""
    if not args:
        # Show global USE flags
        print("→ Global USE flags:")
        subprocess.call(["portageq", "envvar", "USE"])
    else:
        # Show package-specific USE flags
        package = args[0]
        print(f"→ USE flags for {package}:")
        subprocess.call(["emerge", "-pv", package])
    return 0


# ============================================================================
# Repository management
# ============================================================================
def repo_add(repos):
    """Add repositories (overlays)"""
    if not repos:
        print("Usage: evp repo-add <repo> [repo...]")
        return 1
    
    for repo in repos:
        print(f"→ Enabling repository: {repo}")
        ret = run_command(["eselect", "repository", "enable", repo], explain=True)
        if ret != 0:
            print(f"✗ Failed to enable {repo}")
            return ret
    
    print("\n→ Syncing new repositories...")
    return run_command(["emerge", "--sync"], spinner_msg="Syncing repos")


def repo_remove(repos):
    """Remove repositories"""
    if not repos:
        print("Usage: evp repo-remove <repo> [repo...]")
        return 1
    
    for repo in repos:
        print(f"→ Disabling repository: {repo}")
        ret = run_command(["eselect", "repository", "disable", repo], explain=True)
        if ret != 0:
            print(f"✗ Failed to disable {repo}")
    
    return 0


def repo_list():
    """List repositories"""
    print("→ Available repositories:")
    return subprocess.call(["eselect", "repository", "list"])


# ============================================================================
# Keyword management (unstable packages)
# ============================================================================
def keyword_add(packages):
    """Accept unstable keywords for packages"""
    if not packages:
        print("Usage: evp keyword <package> [package...]")
        return 1
    
    # Get system arch
    arch = subprocess.check_output(["portageq", "envvar", "ARCH"]).decode().strip()
    keyword = f"~{arch}"
    
    for package in packages:
        print(f"→ Accepting {keyword} for {package}")
        entry = f"{package} {keyword}"
        
        if DRY_RUN:
            print(f"  Would add to {PACKAGE_KEYWORDS}: {entry}")
        else:
            append_to_file(PACKAGE_KEYWORDS, entry)
    
    print("✓ Done!")
    return 0


def keyword_remove(packages):
    """Remove keyword acceptance for packages"""
    if not packages:
        print("Usage: evp keyword-remove <package> [package...]")
        return 1
    
    for package in packages:
        print(f"→ Removing keyword acceptance for {package}")
        
        if DRY_RUN:
            print(f"  Would remove from {PACKAGE_KEYWORDS}: {package}")
        else:
            remove_from_file(PACKAGE_KEYWORDS, package)
    
    print("✓ Done!")
    return 0


# ============================================================================
# License management
# ============================================================================
def license_add(args):
    """Accept licenses globally or per-package"""
    if not args:
        print("Usage: evp license <license>")
        print("   or: evp license <package> <license>")
        print("Examples:")
        print("  evp license @BINARY-REDISTRIBUTABLE")
        print("  evp license firefox @BINARY-REDISTRIBUTABLE")
        return 1
    
    if len(args) == 1:
        # Global license
        license_name = args[0]
        print(f"→ Accepting license globally: {license_name}")
        
        if DRY_RUN:
            print(f"  Would add to {MAKE_CONF}: ACCEPT_LICENSE=\"{license_name}\"")
            return 0
        
        append_to_file(MAKE_CONF, f'ACCEPT_LICENSE="{license_name}"')
    else:
        # Per-package license
        package = args[0]
        license_name = ' '.join(args[1:])
        print(f"→ Accepting license for {package}: {license_name}")
        entry = f"{package} {license_name}"
        
        if DRY_RUN:
            print(f"  Would add to {PACKAGE_LICENSE}: {entry}")
            return 0
        
        append_to_file(PACKAGE_LICENSE, entry)
    
    print("✓ Done!")
    return 0


# ============================================================================
# Build log viewer
# ============================================================================
def show_logs(args):
    """Show build logs"""
    if args and args[0] == "--failed":
        print("→ Recent failed builds:")
        # Find recent failed build logs
        result = subprocess.run(
            ["find", BUILD_LOG_DIR, "-name", "*.log", "-type", "f", "-mtime", "-7"],
            capture_output=True,
            text=True
        )
        
        if result.stdout:
            logs = result.stdout.strip().split('\n')
            for log in logs[:10]:  # Show last 10
                print(f"  {log}")
        else:
            print("  No recent logs found")
        return 0
    
    elif args:
        package = args[0]
        print(f"→ Looking for build log for {package}...")
        
        # Find most recent log for package
        result = subprocess.run(
            ["find", BUILD_LOG_DIR, "-name", f"*{package}*.log", "-type", "f"],
            capture_output=True,
            text=True
        )
        
        if result.stdout:
            logs = result.stdout.strip().split('\n')
            latest = max(logs, key=os.path.getmtime)
            print(f"→ Showing: {latest}\n")
            subprocess.call(["less", latest])
        else:
            print(f"✗ No build log found for {package}")
        return 0
    
    else:
        print("Usage: evp logs <package>")
        print("   or: evp logs --failed")
        return 1


# ============================================================================
# Configuration file updates
# ============================================================================
def config_update():
    """Update configuration files (etc-update wrapper)"""
    print("→ Checking for configuration updates...")
    
    # Check if there are any updates needed
    result = subprocess.run(
        ["find", "/etc", "-name", "._cfg????_*"],
        capture_output=True,
        text=True
    )
    
    if not result.stdout:
        print("✓ No configuration updates needed!")
        return 0
    
    print("→ Configuration files need updating")
    print("  Launching etc-update...")
    return subprocess.call(["etc-update"])


